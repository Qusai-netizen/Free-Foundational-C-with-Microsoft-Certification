 int examAssignments = 5;

string[] studentsNames = ["Sophia", "Andrew", "Emma", "Logan"];

int[] sophiaScores = { 90, 86, 87, 98, 100, 94, 90 };
int[] andrewScores = { 92, 89, 81, 96, 90, 89 };
int[] emmaScores = { 90, 85, 87, 98, 68, 89, 89, 89 };
int[] loganScores = { 90, 95, 87, 88, 96, 96 };
int[] studentScores = new int[10];

Console.WriteLine("Student\t\tExam Score\tOverall Grade\tExtra Credit\n");

foreach (string currentStudent in studentsNames)
{

    int studentScoresSum = 0;
    int studentExtraCreditsSum = 0;

    decimal studentScore = 0;

    int studentcreditsScore = 0;

    decimal studentOverallScore = 0;

    decimal studentcreditsPoints = 0;

    int StudentCreditsNum = 0;

    int gradedAssignments = 0;

    string currentStudentLetterGrade = "";

    if (currentStudent == "Sophia")
    {
        studentScores = sophiaScores;
    }
    else if (currentStudent == "Andrew")
    {
        studentScores = andrewScores;
    }
    else if (currentStudent == "Emma")
    {
        studentScores = emmaScores;
    }
    else if (currentStudent == "Logan")
    {
        studentScores = loganScores;
    }
    else
    { continue; }

    foreach (int score in studentScores)
    {
        gradedAssignments += 1;

        if (gradedAssignments <= examAssignments)
            studentScoresSum += score;

        else
        {
            studentExtraCreditsSum += score;
            StudentCreditsNum++;
        }
    }

    studentScore = (decimal)studentScoresSum / examAssignments;
    studentcreditsScore = (int)((decimal)studentExtraCreditsSum / StudentCreditsNum);

    studentcreditsPoints = (decimal)studentExtraCreditsSum / 10 / examAssignments;

    studentOverallScore = studentScore + studentcreditsPoints;

    if (studentOverallScore >= 97)
        currentStudentLetterGrade = "A+";

    else if (studentOverallScore >= 93)
        currentStudentLetterGrade = "A";

    else if (studentOverallScore >= 90)
        currentStudentLetterGrade = "A-";

    else if (studentOverallScore >= 87)
        currentStudentLetterGrade = "B+";

    else if (studentOverallScore >= 83)
        currentStudentLetterGrade = "B";

    else if (studentOverallScore >= 80)
        currentStudentLetterGrade = "B-";

    else if (studentOverallScore >= 77)
        currentStudentLetterGrade = "C+";

    else if (studentOverallScore >= 73)
        currentStudentLetterGrade = "C";

    else if (studentOverallScore >= 70)
        currentStudentLetterGrade = "C-";

    else if (studentOverallScore >= 67)
        currentStudentLetterGrade = "D+";

    else if (studentOverallScore >= 63)
        currentStudentLetterGrade = "D";

    else if (studentOverallScore >= 60)
        currentStudentLetterGrade = "D-";
    else
        currentStudentLetterGrade = "F";

    Console.WriteLine($"{currentStudent}:\t\t{studentScore}\t\t{studentOverallScore}\t{currentStudentLetterGrade}\t{studentcreditsScore} ({studentcreditsPoints} pts)");

}

Console.WriteLine("Press the Enter key to continue");
Console.ReadLine();
